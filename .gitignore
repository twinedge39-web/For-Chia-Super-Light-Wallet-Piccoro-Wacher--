# IDE configs
# ===============================
.vscode/
.idea/
*.iml

# ===============================
# Project-specific secrets/config
# ===============================
config.json              # ウォレット設定(メールパスワード等)
chia_watch_state.json    # 既読トランザクション記録

# ===============================
# Chia sensitive files
# ===============================
*.crt
*.key
*.pem

# Chia config / keys / ssl
**/.chia/**/config/ssl/
**/.chia/**/config/ssl/**

# Chia wallet & blockchain DB
**/.chia/**/wallet/db/*.sqlite*
**/.chia/**/db/*.sqlite*

# Peer table / logs
**/.chia/**/*.log
**/.chia/**/*peer_table*.sqlite*
